# Git prompt with timeout protection for large repositories
GIT_PROMPT_TIMEOUT_SECONDS=${GIT_PROMPT_TIMEOUT_SECONDS:-1.0}

_get_git_status_safely() {
    local timeout_seconds="$GIT_PROMPT_TIMEOUT_SECONDS"
    
    # Skip timeout if disabled or command unavailable
    if [ "$(echo "$timeout_seconds <= 0" | bc -l 2>/dev/null || echo 1)" = "1" ] || ! command -v timeout >/dev/null 2>&1; then
        git status --porcelain 2>/dev/null
        return $?
    fi
    
    timeout "$timeout_seconds" git status --porcelain 2>/dev/null
}

_parse_git_changes() {
    local status="$1"
    local has_staged=""
    local has_unstaged=""
    
    if [ -n "$status" ]; then
        # Staged changes: first character is not space or ?
        echo "$status" | grep -q '^[^? ] ' && has_staged="1"
        
        # Unstaged/untracked changes: ?? or . followed by non-space
        echo "$status" | grep -q '^?? \|^.[^ ] ' && has_unstaged="1"
    fi
    
    echo "$has_staged:$has_unstaged"
}

get-git-info(){
    local branch
    branch=$(git symbolic-ref HEAD 2>/dev/null | sed "s/refs\/heads\///g")

    if [ -z "$branch" ]; then
        GIT_BRANCH=""
        GIT_HAS_STAGED=""
        GIT_HAS_UNSTAGED=""
        GIT_TIMEOUT=""
        return 0
    fi

    local status exit_code
    status=$(_get_git_status_safely)
    exit_code=$?
    
    if [ $exit_code -eq 124 ]; then
        # Timeout occurred
        GIT_BRANCH="$branch"
        GIT_HAS_STAGED=""
        GIT_HAS_UNSTAGED=""
        GIT_TIMEOUT="1"
        return 0
    fi
    
    local parsed
    parsed=$(_parse_git_changes "$status")
    
    GIT_BRANCH="$branch"
    GIT_HAS_STAGED="${parsed%%:*}"
    GIT_HAS_UNSTAGED="${parsed#*:}"
    GIT_TIMEOUT=""
}
cur-hist() {
