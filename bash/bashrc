# Git prompt with optional timeout protection
# 
# Large repositories can cause 'git status' to hang, slowing down the prompt.
# This adds optional timeout protection with clean, understandable functions.
#
# Environment variable (optional):
#   GIT_PROMPT_TIMEOUT_MS - Timeout in milliseconds (default: 1000ms = 1 second)
#                           Set to 0 to disable timeout protection entirely
#
# Why 1000ms default? It's a reasonable balance - fast enough for interactive
# use but gives git status time to complete in moderately sized repos.
# Most git status operations complete in <100ms. In very large repos where
# git status might hang for seconds, the timeout prevents prompt delays.

GIT_PROMPT_TIMEOUT_MS=${GIT_PROMPT_TIMEOUT_MS:-1000}

# Helper: Check if timeout command is available
_has_timeout_command() {
    command -v timeout >/dev/null 2>&1
}

# Helper: Convert milliseconds to seconds for timeout command
# Uses bash integer arithmetic to avoid external tools like bc
_ms_to_seconds() {
    local ms="$1"
    # Convert ms to seconds with 3 decimal places using integer arithmetic
    # Example: 1000ms -> 1.000 seconds
    local seconds=$((ms / 1000))
    local remainder=$((ms % 1000))
    printf "%d.%03d\n" "$seconds" "$remainder"
}

# Helper: Get git status with timeout protection
# Returns status via stdout, returns 124 exit code if timeout occurred
_get_git_status_with_timeout() {
    local timeout_ms="$1"
    
    if [ "$timeout_ms" -le 0 ] || ! _has_timeout_command; then
        # No timeout protection
        git status --porcelain 2>/dev/null
        return $?
    fi
    
    local timeout_seconds
    timeout_seconds=$(_ms_to_seconds "$timeout_ms")
    
    # Run git status with timeout
    timeout "$timeout_seconds" git status --porcelain 2>/dev/null
    local exit_code=$?
    
    # Return the exit code (124 means timeout occurred)
    return $exit_code
}

# Helper: Parse git status output to detect changes
_parse_git_status() {
    local status="$1"
    local has_commits=""
    local has_changes=""
    
    if [ -n "$status" ]; then
        # Check for staged changes (first character is not space or ?)
        if echo "$status" | grep -q '^[^? ] '; then
            has_commits="1"
        fi

        # Check for untracked or unstaged changes
        if echo "$status" | grep -q '^?? \|^.[^ ] '; then
            has_changes="1"
        fi
    fi
    
    # Output results (caller can capture with command substitution)
    echo "$has_commits:$has_changes"
}

# Main git info function - clean and focused
get-git-info(){
    # Get git branch (fast operation)
    local branch
    branch=$(git symbolic-ref HEAD 2>/dev/null | sed "s/refs\/heads\///g")

    if [ -z "$branch" ]; then
        GIT_BRANCH=""
        GIT_HAS_COMMITS=""
        GIT_HAS_CHANGES=""
        GIT_TIMEOUT=""
        return 0
    fi

    # Get git status with timeout protection
    local status
    local exit_code
    
    status=$(_get_git_status_with_timeout "$GIT_PROMPT_TIMEOUT_MS")
    exit_code=$?
    
    if [ $exit_code -eq 124 ]; then
        # Timeout occurred
        GIT_BRANCH="$branch"
        GIT_HAS_COMMITS=""
        GIT_HAS_CHANGES=""
        GIT_TIMEOUT="1"
        return 0
    fi
    
    # Parse the status output
    local parsed_result
    parsed_result=$(_parse_git_status "$status")
    
    # Extract results from parsed output
    local has_commits="${parsed_result%%:*}"
    local has_changes="${parsed_result#*:}"
    
    # Set global variables for use in precmd
    GIT_BRANCH="$branch"
    GIT_HAS_COMMITS="$has_commits"
    GIT_HAS_CHANGES="$has_changes"
    GIT_TIMEOUT=""
}

cur-hist() {
    echo "$(history | tail -n 1 | awk '{print $1}')"
}

precmd(){
    # Write bash history
    # history -a only appends and doesn't create the file if it doesn't exist
    # So we ensure the file exists first, then append
    [ -f "$HISTFILE" ] && history -a || history -w

    # Single optimized call to get all git info
    get-git-info

    SPACE=""
    if [ -n "$GIT_BRANCH" ]; then
        # Check if git status timed out
        if [ -n "$GIT_TIMEOUT" ]; then
            # Show timeout indicator instead of status details
            PROMPT_GIT="${bldwht}(${bldylw}$GIT_BRANCH${bldred}!${bldwht})"
        else
            # Check for staged changes (commits ready)
            if [ -n "$GIT_HAS_COMMITS" ]; then
                COMMITS="${bldcyn}×"
                SPACE=" "
            else
                COMMITS=""
            fi

            # Check for unstaged/untracked changes
            if [ -n "$GIT_HAS_CHANGES" ]; then
                CHANGES="${bldcyn}+"
                SPACE=" "
            else
                CHANGES=""
            fi

            PROMPT_GIT="${bldwht}(${bldgrn}$GIT_BRANCH$SPACE$CHANGES$COMMITS${bldwht})"
        fi
    else
        PROMPT_GIT=""
    fi

    if [[ $EUID -ne 0 ]]; then
        PROMPT_MAIN="${bldpur}(${txtblu}\u${bldpur}@${txtblu}\h${bldpur})${txtblu}\w${txtrst}"
    else
        PROMPT_MAIN="${bldpur}(${txtblu}\u${bldpur}@${txtblu}\h${bldpur})${txtblu}\w${txtrst}"
    fi

    if [[ $STY != "" ]]; then
        PROMPT_SCREEN="${bldpur}[${bldgrn}$(echo $STY | grep -o ^[0-9]*)${bldpur}]"
    else
        PROMPT_SCREEN="${bldpur}[${bldred}---${bldpur}]"
    fi

    PROMPT_PID="${bldpur}{${bldcyn}$$${bldpur}}"

    export PS1="${PROMPT_PID}${PROMPT_SCREEN}${PROMPT_MAIN}${PROMPT_GIT}${bldpur}\n$ ${txtrst}"
    export PS2="${bldwht}↪ ${txtrst}"

}

