# Optimized git prompt with optional timeout protection
# 
# Large repositories can cause 'git status' to hang, slowing down the prompt.
# This implementation adds optional timeout protection while keeping the core
# logic simple and decoupled.
#
# Environment variables (all optional):
#   GIT_PROMPT_TIMEOUT_MS - Timeout in milliseconds (default: 500ms)
#                           Set to 0 to disable timeout protection
#   GIT_PROMPT_CACHE_SEC  - Cache duration in seconds (default: 0 = disabled)
#                           Caching is minimal and only prevents repeated
#                           timeouts in the same directory
#
# Why 500ms default? It's short enough to not block typing but long enough
# for most repositories. Adjust based on your system performance.
#
# Cache behavior: When enabled, only timeout results are cached (not status).
# This prevents repeated timeouts when navigating large repos.

GIT_PROMPT_TIMEOUT_MS=${GIT_PROMPT_TIMEOUT_MS:-500}
GIT_PROMPT_CACHE_SEC=${GIT_PROMPT_CACHE_SEC:-0}

# Helper: Run git status with optional timeout
# Returns status output via stdout, returns 124 if timeout occurred
git-status-with-timeout() {
    local timeout_ms=$1
    
    # Convert milliseconds to seconds for timeout command
    local timeout_seconds=$(echo "scale=3; $timeout_ms / 1000" | bc 2>/dev/null || echo "0.5")
    
    if [ "$timeout_ms" -eq 0 ] || ! command -v timeout >/dev/null 2>&1; then
        # No timeout protection requested or timeout command not available
        git status --porcelain 2>/dev/null
        return $?
    fi
    
    # Run with timeout protection
    timeout $timeout_seconds git status --porcelain 2>/dev/null
    local exit_code=$?
    
    if [ $exit_code -eq 124 ]; then
        # Timeout occurred
        echo "TIMEOUT"
        return 124
    fi
    
    return $exit_code
}

# Core git info function - simple and focused
get-git-info(){
    # Get git branch (fast operation)
    local branch=$(git symbolic-ref HEAD 2>/dev/null | sed "s/refs\/heads\///g")

    if [ -z "$branch" ]; then
        GIT_BRANCH=""
        GIT_HAS_COMMITS=""
        GIT_HAS_CHANGES=""
        GIT_TIMEOUT=""
        return 0
    fi

    # Check cache for timeout results (if caching enabled)
    if [ "$GIT_PROMPT_CACHE_SEC" -gt 0 ] && \
       [ -n "$GIT_CACHE_TIMEOUT_TIME" ] && \
       [ -n "$GIT_CACHE_TIMEOUT_DIR" ] && \
       [ "$PWD" = "$GIT_CACHE_TIMEOUT_DIR" ] && \
       [ $(($(date +%s) - GIT_CACHE_TIMEOUT_TIME)) -lt "$GIT_PROMPT_CACHE_SEC" ]; then
        # We recently timed out in this directory, skip git status
        GIT_BRANCH="$branch"
        GIT_HAS_COMMITS=""
        GIT_HAS_CHANGES=""
        GIT_TIMEOUT="1"
        return 0
    fi

    # Get git status with optional timeout protection
    local status
    status=$(git-status-with-timeout "$GIT_PROMPT_TIMEOUT_MS")
    local status_exit=$?
    
    if [ $status_exit -eq 124 ]; then
        # Timeout occurred
        GIT_BRANCH="$branch"
        GIT_HAS_COMMITS=""
        GIT_HAS_CHANGES=""
        GIT_TIMEOUT="1"
        
        # Cache timeout result if caching enabled
        if [ "$GIT_PROMPT_CACHE_SEC" -gt 0 ]; then
            GIT_CACHE_TIMEOUT_TIME=$(date +%s)
            GIT_CACHE_TIMEOUT_DIR="$PWD"
        fi
        return 0
    fi

    # Parse status output once for both staged and unstaged changes
    local has_commits=""
    local has_changes=""

    if [ -n "$status" ] && [ "$status" != "TIMEOUT" ]; then
        # Check for staged changes (first character is not space or ?)
        if echo "$status" | grep -q '^[^? ] '; then
            has_commits="1"
        fi

        # Check for untracked or unstaged changes
        if echo "$status" | grep -q '^?? \|^.[^ ] '; then
            has_changes="1"
        fi
    fi

    # Set global variables for use in precmd
    GIT_BRANCH="$branch"
    GIT_HAS_COMMITS="$has_commits"
    GIT_HAS_CHANGES="$has_changes"
    GIT_TIMEOUT=""
    
    # Clear timeout cache on successful execution
    GIT_CACHE_TIMEOUT_TIME=""
    GIT_CACHE_TIMEOUT_DIR=""
}

cur-hist() {
    echo "$(history | tail -n 1 | awk '{print $1}')"
}

precmd(){
    # Write bash history
    # history -a only appends and doesn't create the file if it doesn't exist
    # So we ensure the file exists first, then append
    [ -f "$HISTFILE" ] && history -a || history -w

    # Single optimized call to get all git info
    get-git-info

    SPACE=""
    if [ -n "$GIT_BRANCH" ]; then
        # Check if git status timed out
        if [ -n "$GIT_TIMEOUT" ]; then
            # Show timeout indicator instead of status details
            PROMPT_GIT="${bldwht}(${bldylw}$GIT_BRANCH${bldred}!${bldwht})"
        else
            # Check for staged changes (commits ready)
            if [ -n "$GIT_HAS_COMMITS" ]; then
                COMMITS="${bldcyn}×"
                SPACE=" "
            else
                COMMITS=""
            fi

            # Check for unstaged/untracked changes
            if [ -n "$GIT_HAS_CHANGES" ]; then
                CHANGES="${bldcyn}+"
                SPACE=" "
            else
                CHANGES=""
            fi

            PROMPT_GIT="${bldwht}(${bldgrn}$GIT_BRANCH$SPACE$CHANGES$COMMITS${bldwht})"
        fi
    else
        PROMPT_GIT=""
    fi

    if [[ $EUID -ne 0 ]]; then
        PROMPT_MAIN="${bldpur}(${txtblu}\u${bldpur}@${txtblu}\h${bldpur})${txtblu}\w${txtrst}"
    else
        PROMPT_MAIN="${bldpur}(${txtblu}\u${bldpur}@${txtblu}\h${bldpur})${txtblu}\w${txtrst}"
    fi

    if [[ $STY != "" ]]; then
        PROMPT_SCREEN="${bldpur}[${bldgrn}$(echo $STY | grep -o ^[0-9]*)${bldpur}]"
    else
        PROMPT_SCREEN="${bldpur}[${bldred}---${bldpur}]"
    fi

    PROMPT_PID="${bldpur}{${bldcyn}$$${bldpur}}"

    export PS1="${PROMPT_PID}${PROMPT_SCREEN}${PROMPT_MAIN}${PROMPT_GIT}${bldpur}\n$ ${txtrst}"
    export PS2="${bldwht}↪ ${txtrst}"

}

